{
  "name": "arcadia-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Arcadia AI - Multi-Agent Collaborative Novel Workspace. Monorepo root.",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:web": "pnpm --filter @arcadia/web dev",
    "dev:api": "pnpm --filter @arcadia/server dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "clean": "pnpm -r run clean && mavis-trash node_modules .bak-stage0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "typescript": "~5.8.2",
    "@types/node": "^22.14.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
