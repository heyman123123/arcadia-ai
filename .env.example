# === Server 端口 ===
PORT=3000

# === Vite dev server 端口 ===
VITE_PORT=5173

# === 存储后端 ===
# 'sqlite'(默认) 数据落盘到 apps/server/data/arcadia.db
# 'memory'   纯内存,进程重启数据丢失(测试用)
STORAGE=sqlite

# === AI Provider(OpenAI 兼容协议) ===
# 留空 = 该 provider 不启用
# 至少配一个 OPENAI_API_KEY 或 MINIMAX_API_KEY 才能用 AI 功能

# AI_PROVIDER 控制优先级:auto(默认,minimax 优先) / openai / minimax
AI_PROVIDER=auto

# --- OpenAI 官方 ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- MiniMax(中国 MiniMax,M2/M2.7/M3 系列,OpenAI 协议兼容) ---
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2

# === 可选:APP_URL(用于 OAuth 回调) ===
APP_URL=
